{
  "name": "litcode",
  "version": "1.0.0",
  "description": "Local-first LeetCode enhancement Chrome extension: autocomplete, solution videos, spaced-repetition review, solution snapshots, and a chat-style AI tutor (BYOK).",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "test": "vitest run",
    "lint": "eslint .",
    "pack": "wxt build && rm -rf extension && cp -r .output/chrome-mv3 extension",
    "postinstall": "wxt prepare"
  },
  "keywords": [
    "leetcode",
    "chrome-extension",
    "wxt"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "dompurify": "^3.4.11",
    "marked": "^18.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.2.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9",
    "wxt": "^0.20.27"
  }
}
